# Copy this file to .env and fill in real values. Never commit .env.

# Postgres connection string (Neon in production, local Docker in dev)
# Format: postgresql://user:password@host:port/dbname
DATABASE_URL=postgresql://user:password@localhost:5432/weather

# Comma-separated list of SMHI station IDs to ingest
# 52350 = Malmö A, 62010 = Helsingborg, 53430 = Lund
SMHI_STATION_IDS=52350,62010,53430

# Comma-separated SMHI parameter IDs to collect
# 1 = air temperature (°C), 6 = relative humidity (%), 7 = precipitation (mm)
SMHI_PARAMETER_IDS=1,6
